<Window x:Class="VisionInspection.Views.LoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="用户登录" Height="260" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="ToolWindow" ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="VisionInspection" FontSize="18" FontWeight="Bold" Foreground="#0078D7" Grid.Row="0"/>
        <TextBlock Text="机器视觉检测系统" FontSize="11" Foreground="Gray" Grid.Row="1" Margin="0,4,0,12"/>
        <TextBlock Text="账号" Grid.Row="2" Margin="0,8,0,2"/>
        <ComboBox Name="CmbUser" Grid.Row="3" Height="28">
            <ComboBoxItem Content="管理员 (Admin)" Tag="Admin" IsSelected="True"/>
            <ComboBoxItem Content="工程师 (Engineer)" Tag="Engineer"/>
            <ComboBoxItem Content="操作员 (Operator)" Tag="Operator"/>
        </ComboBox>
        <TextBlock Text="密码" Grid.Row="4" Margin="0,12,0,2"/>
        <PasswordBox Name="TxtPassword" Grid.Row="5" Height="28" KeyDown="TxtPassword_KeyDown"/>
        <Button Content="登  录" Grid.Row="5" HorizontalAlignment="Right" Width="100" Height="40"
                Background="#0078D7" Foreground="White" FontSize="14" FontWeight="Bold"
                Click="BtnLogin_Click" Margin="0,50,0,0"/>
    </Grid>
</Window>
