<Window x:Class="VisionInspection.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VisionInspection - 机器视觉检测系统"
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        MinHeight="680" MinWidth="1024">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="0.25*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: 菜单栏 -->
        <Menu Grid.Row="0" Name="MainMenu">
            <MenuItem Header="文件(_F)">
                <MenuItem Name="MnuFileLoadVpp" Header="加载VPP(_L)..." Click="MenuLoadVpp_Click"/>
                <MenuItem Name="MnuFileSaveVpp" Header="保存VPP(_S)" Click="MenuSaveVpp_Click"/>
                <MenuItem Name="MnuFileSaveVppAs" Header="另存VPP..." Click="MenuSaveVppAs_Click"/>
                <Separator/>
                <MenuItem Name="MnuFileExit" Header="退出(_X)" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="视觉工具(_V)">
                <MenuItem Header="工具链编辑器(_E)..." Click="MenuToolEditor_Click"/>
                <MenuItem Header="变量监视(_W)..." Click="MenuVarMonitor_Click"/>
                <MenuItem Header="检测效果图(_R)..." Click="MenuResultViewer_Click"/>
            </MenuItem>
            <MenuItem Header="配方(_P)">
                <MenuItem Header="新建配方(_N)..." Click="MenuRecipeNew_Click"/>
                <MenuItem Header="复制配方(_C)..." Click="MenuRecipeCopy_Click"/>
                <MenuItem Header="重命名配方(_R)..." Click="MenuRecipeRename_Click"/>
                <Separator/>
                <MenuItem Header="切换配方(_S)..." Click="MenuRecipeSwitch_Click"/>
            </MenuItem>
            <MenuItem Header="通讯(_C)">
                <MenuItem Header="TCP 通讯(_T)..." Click="MenuTcpOpen_Click"/>
                <MenuItem Header="串口通讯(_S)..." Click="MenuSerialOpen_Click"/>
            </MenuItem>
            <MenuItem Header="用户(_U)">
                <MenuItem Header="登录(_L)..." Click="MenuUserLogin_Click"/>
                <MenuItem Header="退出登录(_O)" Click="MenuUserLogout_Click"/>
                <MenuItem Header="锁定界面(_K)" Click="MenuUserLock_Click"/>
                <Separator/>
                <MenuItem Header="修改密码(_P)..." Click="MenuUserChPwd_Click"/>
            </MenuItem>
            <MenuItem Header="设置(_S)">
                <MenuItem Header="系统设置(_T)..." Click="MenuSettings_Click"/>
            </MenuItem>
            <MenuItem Header="帮助(_H)">
                <MenuItem Header="运行界面(_R)..." Click="MenuOperatorView_Click"/>
                <MenuItem Header="关于(_A)..." Click="MenuHelpAbout_Click"/>
            </MenuItem>
        </Menu>

        <!-- Row 1: 工具栏 -->
        <ToolBar Grid.Row="1" Name="MainToolBar">
            <Button Content="📂 打开图片" Click="BtnOpenImage_Click" Margin="2" Padding="8,3"/>
            <Button Content="📁 打开图片文件夹" Click="BtnOpenFolder_Click" Margin="2" Padding="8,3"/>
            <Separator/>
            <Button Content="▶ 运行一次" Click="BtnRunOnce_Click" Margin="2" Padding="8,3" Foreground="Green" FontWeight="Bold" ToolTip="F5"/>
            <Button Content="⏩ 连续运行" Click="BtnRunCont_Click" Margin="2" Padding="8,3" Foreground="DarkGreen" ToolTip="F6"/>
            <Button Content="⏹ 停止" Click="BtnStop_Click" Margin="2" Padding="8,3" Foreground="Red" ToolTip="F7"/>
            <Separator/>
            <Label Content="模式:" Margin="4,0,2,0"/>
            <ComboBox Name="CmbRunMode" Width="90" SelectedIndex="0">
                <ComboBoxItem Content="离线模式" Tag="Offline"/>
                <ComboBoxItem Content="在线模式" Tag="Online"/>
            </ComboBox>
        </ToolBar>

        <!-- Row 2: 主内容区 (图像 + 右侧面板) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- 中央：图像显示区域 -->
            <Border Grid.Column="0" Name="ImageBorder" Background="#1E1E1E" Margin="1">
                <WindowsFormsHost Name="ImageHost" Margin="0"/>
            </Border>

            <!-- 右侧面板 -->
            <Grid Grid.Column="1" Margin="1,0,1,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Row 0：当班统计 -->
                <Border Grid.Row="0" BorderBrush="#DDDDDD" BorderThickness="1" Background="#FAFAFA" Margin="0,1,0,2">
                    <StackPanel>
                        <Border Background="#E8E8E8" Padding="8,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="📊 当班统计" FontWeight="Bold" FontSize="12" VerticalAlignment="Center"/>
                                <Button Grid.Column="1" Content="清除" Width="50" Height="24" FontSize="10"
                                        Click="BtnStatClear_Click" Padding="4,1"/>
                            </Grid>
                        </Border>
                        <WrapPanel Margin="8,5" Orientation="Horizontal">
                            <StackPanel Width="55" Margin="2">
                                <TextBlock Text="OK" Foreground="Gray" FontSize="10"/>
                                <TextBlock Name="TxtStatOk" Text="0" Foreground="#009600" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Width="55" Margin="2">
                                <TextBlock Text="NG" Foreground="Gray" FontSize="10"/>
                                <TextBlock Name="TxtStatNg" Text="0" Foreground="Red" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Width="55" Margin="2">
                                <TextBlock Text="总数" Foreground="Gray" FontSize="10"/>
                                <TextBlock Name="TxtStatTotal" Text="0" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Width="60" Margin="2">
                                <TextBlock Text="良率" Foreground="Gray" FontSize="10"/>
                                <TextBlock Name="TxtStatYield" Text="---" Foreground="#0064C8" FontSize="16" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel Width="65" Margin="2">
                                <TextBlock Text="耗时" Foreground="Gray" FontSize="10"/>
                                <TextBlock Name="TxtStatCycle" Text="---" Foreground="DimGray" FontSize="14" FontWeight="Bold"/>
                            </StackPanel>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Row 1：当班统计柱状图 -->
                <Border Grid.Row="1" BorderBrush="#DDDDDD" BorderThickness="1" Margin="0,1,0,2" Height="180">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#E8E8E8" Padding="6,3">
                            <TextBlock Text="📊 当班统计柱状图" FontWeight="Bold" FontSize="11"/>
                        </Border>
                        <Grid Name="ChartGrid" Margin="8,6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <!-- 柱状图区域 -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
                                <StackPanel Name="BarOk" Width="50" Margin="6,0" VerticalAlignment="Bottom"/>
                                <StackPanel Name="BarNg" Width="50" Margin="6,0" VerticalAlignment="Bottom"/>
                                <StackPanel Name="BarTotal" Width="50" Margin="6,0" VerticalAlignment="Bottom"/>
                                <StackPanel Name="BarYield" Width="50" Margin="6,0" VerticalAlignment="Bottom"/>
                            </StackPanel>
                            <!-- 标签行 -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                                <TextBlock Text="OK" Width="50" TextAlignment="Center" Margin="6,0" FontSize="10"/>
                                <TextBlock Text="NG" Width="50" TextAlignment="Center" Margin="6,0" FontSize="10"/>
                                <TextBlock Text="总数" Width="50" TextAlignment="Center" Margin="6,0" FontSize="10"/>
                                <TextBlock Text="良率" Width="50" TextAlignment="Center" Margin="6,0" FontSize="10"/>
                            </StackPanel>
                        </Grid>
                    </DockPanel>
                </Border>

                <!-- Row 2：ToolBlock 编辑器入口 -->
                <Border Grid.Row="2" BorderBrush="#DDDDDD" BorderThickness="1" Margin="0,1,0,1" Background="#FAFAFA">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="🔧" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="VisionPro 工具链编辑器" FontSize="13" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="#333"/>
                        <TextBlock Text="在独立窗口中编辑视觉工具链" FontSize="11"
                                   HorizontalAlignment="Center" Foreground="Gray" Margin="0,4,0,12"/>
                        <Button Content="📂 打开编辑器" Height="36" Width="180"
                                Background="#0078D7" Foreground="White" FontSize="13" FontWeight="Bold"
                                Click="BtnOpenEditor_Click" Cursor="Hand"/>
                        <TextBlock Name="TxtEditorStatus" Text="未加载 VPP" FontSize="10"
                                   HorizontalAlignment="Center" Foreground="DimGray" Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Row 3: 日志 (全宽) -->
        <Border Grid.Row="3" BorderBrush="#DDDDDD" BorderThickness="0,1,0,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#E8E8E8" Padding="6,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="📋 实时日志" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <CheckBox Name="ChkLogInfo" Content="信息" IsChecked="True" Margin="4,0" FontSize="10" VerticalAlignment="Center"/>
                            <CheckBox Name="ChkLogWarn" Content="警告" IsChecked="True" Margin="4,0" FontSize="10" VerticalAlignment="Center"/>
                            <CheckBox Name="ChkLogError" Content="错误" IsChecked="True" Margin="4,0" FontSize="10" VerticalAlignment="Center"/>
                            <CheckBox Name="ChkLogDebug" Content="调试" IsChecked="False" Margin="4,0" FontSize="10" VerticalAlignment="Center" Foreground="Gray"/>
                            <Button Name="BtnLogPause" Content="暂停" Click="BtnLogPause_Click" Margin="8,0,2,0" Padding="6,2" FontSize="10"/>
                            <Button Name="BtnLogClear" Content="清空" Click="BtnLogClear_Click" Margin="2,0,6,0" Padding="6,2" FontSize="10"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <DataGrid Name="LogGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          HeadersVisibility="Column" CanUserResizeRows="False"
                          SelectionMode="Single" GridLinesVisibility="Horizontal"
                          FontSize="11" RowHeight="20" EnableRowVirtualization="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="时间" Width="140" Binding="{Binding Time}"/>
                        <DataGridTextColumn Header="分类" Width="55" Binding="{Binding Category}"/>
                        <DataGridTextColumn Header="级别" Width="50" Binding="{Binding Level}"/>
                        <DataGridTextColumn Header="用户" Width="70" Binding="{Binding User}"/>
                        <DataGridTextColumn Header="消息" Width="*" Binding="{Binding Message}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>

        <!-- Row 4: 状态栏 -->
        <StatusBar Grid.Row="4" Name="MainStatusBar">
            <StatusBarItem><TextBlock Name="StsMode" Text="  离线模式  " Margin="2,0"/></StatusBarItem>
            <Separator/>
            <StatusBarItem><TextBlock Name="StsJob" Text="VPP: 未加载" Margin="4,0"/></StatusBarItem>
            <Separator/>
            <StatusBarItem><TextBlock Name="StsRecipe" Text="配方: 1" Margin="4,0"/></StatusBarItem>
            <Separator/>
            <StatusBarItem><TextBlock Name="StsTcp" Text="  TCP: 未连接  " Margin="4,0"/></StatusBarItem>
            <Separator/>
            <StatusBarItem><TextBlock Name="StsFrame" Text="帧率: --" Margin="4,0"/></StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <Button Name="BtnNotify" Content="🔔" Width="30" Height="20" FontSize="10"
                        Click="BtnNotify_Click" ToolTip="异常通知"
                        Foreground="#87CEEB" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Name="StsUser" Text="  用户: 操作员  " Margin="4,0"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Name="StsSysInfo" Text="CPU --%  RAM --/--GB  D: --GB" Margin="4,0" FontSize="10"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
