<Window x:Class="VisionInspection.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="系统设置" Height="600" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="ToolWindow">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="⚙ 系统设置" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- 相机原图 -->
        <GroupBox Grid.Row="1" Header="相机原图" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <CheckBox Name="ChkRawImage" Content="开启原图存储" Margin="0,4" FontSize="13"/>
                <StackPanel Orientation="Horizontal" Margin="0,6">
                    <TextBlock Text="图片格式：" VerticalAlignment="Center" Width="80"/>
                    <ComboBox Name="CmbRawFormat" Width="90" SelectedIndex="0">
                        <ComboBoxItem Content="BMP"/>
                        <ComboBoxItem Content="PNG"/>
                        <ComboBoxItem Content="JPG"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6">
                    <TextBlock Text="保留天数：" VerticalAlignment="Center" Width="80"/>
                    <TextBox Name="TxtRawRetention" Width="60" Text="30" TextAlignment="Center"/>
                    <TextBlock Text=" 天（0=不自动清理）" VerticalAlignment="Center" Foreground="Gray" FontSize="11"/>
                </StackPanel>
                <TextBlock Name="LblRawLastClean" Foreground="Gray" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- 检测效果图 -->
        <GroupBox Grid.Row="2" Header="检测效果图" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <CheckBox Name="ChkImageSave" Content="开启检测效果图存储" Margin="0,4" FontSize="13"/>
                <StackPanel Orientation="Horizontal" Margin="0,6">
                    <TextBlock Text="保存条件：" VerticalAlignment="Center" Width="80"/>
                    <ComboBox Name="CmbImageCondition" Width="90" SelectedIndex="0">
                        <ComboBoxItem Content="全部保存"/>
                        <ComboBoxItem Content="仅 OK"/>
                        <ComboBoxItem Content="仅 NG"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6">
                    <TextBlock Text="保留天数：" VerticalAlignment="Center" Width="80"/>
                    <TextBox Name="TxtImageRetention" Width="60" Text="30" TextAlignment="Center"/>
                    <TextBlock Text=" 天（0=不自动清理）" VerticalAlignment="Center" Foreground="Gray" FontSize="11"/>
                </StackPanel>
                <TextBlock Name="LblImageLastClean" Foreground="Gray" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- 日志 -->
        <GroupBox Grid.Row="3" Header="日志" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6">
                    <TextBlock Text="保留天数：" VerticalAlignment="Center" Width="80"/>
                    <TextBox Name="TxtLogRetention" Width="60" Text="30" TextAlignment="Center"/>
                    <TextBlock Text=" 天（0=不自动清理）" VerticalAlignment="Center" Foreground="Gray" FontSize="11"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,6">
                    <TextBlock Text="单文件上限：" VerticalAlignment="Center" Width="80"/>
                    <TextBox Name="TxtLogMaxSize" Width="60" Text="50" TextAlignment="Center"/>
                    <TextBlock Text=" MB（超出自动切割）" VerticalAlignment="Center" Foreground="Gray" FontSize="11"/>
                </StackPanel>
                <TextBlock Name="LblLogLastClean" Foreground="Gray" FontSize="11" Margin="0,2,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- 底部按钮 -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Width="80" Height="30" Click="BtnSave_Click"
                    Background="#007acc" Foreground="White" FontSize="13"/>
            <Button Content="取消" Width="80" Height="30" Click="BtnCancel_Click"
                    Margin="10,0,0,0" FontSize="13"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</Window>
